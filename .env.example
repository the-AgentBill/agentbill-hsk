# Wallet that receives USDC payments (your API owner wallet)
RECEIVING_ADDRESS=0xYourReceivingAddress

# Facilitator wallet — submits Permit2.permitTransferFrom() on-chain
# Must be funded with HSK for gas. DO NOT reuse your receiving address.
FACILITATOR_PRIVATE_KEY=0xYourFacilitatorPrivateKey

# Agent wallet — pays for API calls (client-side demo)
AGENT_PRIVATE_KEY=0xYourAgentPrivateKey
